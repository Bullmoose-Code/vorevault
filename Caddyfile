{
    # Allow large uploads (matches tusd -max-size=10 GiB)
    servers {
        max_header_size 64KB
    }
}

:80 {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Resumable uploads handled by tusd (preserve /files/ prefix; tusd -base-path matches)
    handle /files/* {
        reverse_proxy tusd:8080 {
            flush_interval -1
        }
    }

    # Everything else → Next.js
    handle {
        reverse_proxy app:3000
    }

    request_body {
        max_size 11GB
    }
}
